{
  "name": "bookmark",
  "version": "1.0.0",
  "description": "A bookmark manager for me.",
  "license": "0BSD",
  "author": "iwate",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:e2e": "node scripts/test-e2e.mjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "wrangler d1 migrations apply bookmark --local && wrangler dev src/worker.ts",
    "deploy": "wrangler d1 migrations apply bookmark --remote --config wrangler.prod.toml && wrangler deploy --config wrangler.prod.toml"
  },
  "dependencies": {
    "hono": "^4.8.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250605.0",
    "@vitest/coverage-v8": "^2.1.8",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8",
    "wrangler": "^4.19.1"
  }
}
