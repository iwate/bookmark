# package.jsonで指定されたNode.jsのバージョンを厳密にチェックする
engine-strict=true

# npm installやnpm ciの実行時にパッケージのインストールスクリプトを実行しない
# セキュリティリスクを軽減するための設定
ignore-scripts=true

# パッケージ公開から指定日数経過するまでインストールを待機する（日単位）
# 新規公開パッケージの脆弱性や問題を回避するための設定
min-release-age=7

# Node.jsの実行時オプション
# ※ webpackの実行には多くの権限が必要
# --permission: 権限モデルを有効化
# --allow-fs-read=${PWD}: 現在の作業ディレクトリの読み取りを許可
# --allow-fs-write=${PWD}: 現在の作業ディレクトリへの書き込みを許可
# --allow-addons: ネイティブアドオンの使用を許可
# --allow-child-process: 子プロセスの生成を許可
# --allow-worker: ワーカースレッドの使用を許可
#node-options=--permission --allow-fs-read=${PWD} --allow-fs-write=${PWD} --allow-addons --allow-child-process --allow-worker

# カスタムnpmレジストリの設定
# 悪意あるパッケージをインストール前にブロックする
# https://flatt.tech/takumi/features/guard
registry=https://npm.flatt.tech/